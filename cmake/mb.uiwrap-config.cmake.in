set(MB_UIWRAP_VERSION @PROJECT_VERSION@)

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(mb.util CONFIG REQUIRED)
@MB_UIWRAP_CONFIG_BACKEND_DEPENDENCIES@

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake")

target_link_libraries(mb::uiwrap INTERFACE mb::util)

set(@PROJECT_NAME@_FOUND TRUE)
check_required_components(@PROJECT_NAME@)
